{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://maricoparecords.local/mrp/release.schema.json",
  "title": "MRP Release Record",
  "type": "object",
  "required": ["release"],
  "additionalProperties": false,
  "properties": {
    "release": {
      "type": "object",
      "required": [
        "id",
        "slug",
        "title",
        "artist_id",
        "model",
        "release_type",
        "status",
        "release_date",
        "cover_image",
        "seo"
      ],
      "additionalProperties": false,
      "properties": {
        "id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
        "slug": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
        "title": {"type": "string", "minLength": 1},
        "artist_id": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
        "model": {"type": "string", "enum": ["song", "album"]},
        "release_type": {"type": "string", "enum": ["single", "ep", "album"]},
        "status": {
          "type": "string",
          "enum": ["draft", "staged", "verified", "approved", "live", "failed", "archived"]
        },
        "release_date": {"type": ["string", "null"], "format": "date"},
        "label": {"type": ["string", "null"]},
        "publisher": {"type": ["string", "null"]},
        "upc": {"type": ["string", "null"]},
        "catalog_number": {"type": ["string", "null"]},
        "cover_image": {"type": "string", "minLength": 1},
        "hero_image": {"type": ["string", "null"]},
        "summary": {"type": ["string", "null"]},
        "description": {"type": ["string", "null"]},
        "credits": {"$ref": "#/$defs/credits"},
        "links": {"$ref": "#/$defs/links"},
        "seo": {
          "type": "object",
          "required": ["title", "description"],
          "additionalProperties": false,
          "properties": {
            "title": {"type": "string", "minLength": 1},
            "description": {"type": "string", "minLength": 1}
          }
        },
        "song": {"$ref": "#/$defs/song"},
        "tracks": {
          "type": "array",
          "minItems": 1,
          "items": {"$ref": "#/$defs/song"}
        },
        "automation": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "allow_auto_publish": {"type": "boolean"}
          }
        }
      },
      "allOf": [
        {
          "if": {"properties": {"model": {"const": "song"}}, "required": ["model"]},
          "then": {
            "required": ["song"],
            "properties": {"release_type": {"const": "single"}}
          }
        },
        {
          "if": {"properties": {"model": {"const": "album"}}, "required": ["model"]},
          "then": {
            "required": ["tracks"],
            "properties": {"release_type": {"enum": ["ep", "album"]}}
          }
        }
      ]
    }
  },
  "$defs": {
    "credits": {
      "type": "object",
      "additionalProperties": {"type": ["string", "null"]},
      "properties": {
        "primary_artist": {"type": ["string", "null"]},
        "songwriter": {"type": ["string", "null"]},
        "producer": {"type": ["string", "null"]},
        "mastering": {"type": ["string", "null"]}
      }
    },
    "links": {
      "type": "object",
      "additionalProperties": {"type": ["string", "null"]},
      "properties": {
        "spotify": {"type": ["string", "null"]},
        "apple_music": {"type": ["string", "null"]},
        "youtube_music": {"type": ["string", "null"]},
        "bandcamp": {"type": ["string", "null"]},
        "soundcloud": {"type": ["string", "null"]}
      }
    },
    "song": {
      "type": "object",
      "required": ["title", "slug", "explicit", "instrumental"],
      "additionalProperties": false,
      "properties": {
        "number": {"type": ["integer", "null"], "minimum": 0},
        "title": {"type": "string", "minLength": 1},
        "slug": {"type": "string", "pattern": "^[a-z0-9][a-z0-9-]*$"},
        "isrc": {"type": ["string", "null"]},
        "duration": {"type": ["string", "null"]},
        "explicit": {"type": "boolean"},
        "instrumental": {"type": "boolean"},
        "preview_audio": {"type": ["string", "null"]},
        "lyrics_text": {"type": ["string", "null"]},
        "lyrics_source": {"type": ["string", "null"]},
        "links": {"$ref": "#/$defs/links"}
      }
    }
  }
}

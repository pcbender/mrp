---
interface Props {
  title: string;
  titleAscii?: string;
  artist: string;
  href: string;
  type?: string;
  coverImage?: string;
  summary?: string;
  rich?: boolean;
  releaseDate?: string;
}

const { title, titleAscii, artist, href, type = "Single", coverImage, summary = "", rich = false, releaseDate = "" } = Astro.props;
const cleanSummary = cleanMarkdownText(summary);
const searchText = [title, titleAscii, artist, type, releaseDate, cleanSummary].filter(Boolean).join(" ");

function cleanMarkdownText(value: string) {
  return String(value)
    .replace(/\*\*([^*]+)\*\*/g, " $1 ")
    .replace(/__([^_]+)__/g, " $1 ")
    .replace(/\*([^*]+)\*/g, " $1 ")
    .replace(/_([^_]+)_/g, " $1 ")
    .replace(/"\s*([^"]*?)\s*"/g, '"$1"')
    .replace(/“\s+/g, "“")
    .replace(/\s+”/g, "”")
    .replace(/([,.;:!?])(["“])/g, "$1 $2")
    .replace(/(["”])([a-z])/g, "$1 $2")
    .replace(/\s+([,.;:!?])/g, "$1")
    .replace(/\s+/g, " ")
    .trim();
}
---
<article
  class:list={["release-card", rich && "release-card-rich"]}
  data-release-card
  data-release-title={title}
  data-release-artist={artist}
  data-release-type={type}
  data-release-date={releaseDate}
  data-release-search={searchText}
>
  <a href={href} aria-label={`${title} by ${artist}`}>
    {coverImage ? <img class="cover-image" src={coverImage} alt="" loading="lazy" /> : <span class="cover-swatch" aria-hidden="true"></span>}
    <span class="card-kicker">{type}</span>
    <h3>{title}</h3>
    {rich && <span class="release-card-artist">{artist}</span>}
    {rich ? (cleanSummary && <p>{cleanSummary}</p>) : <p>{artist}</p>}
    {rich && <span class="release-more">More...</span>}
  </a>
</article>

<style>
  .release-card {
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    transition: box-shadow var(--transition), transform var(--transition);
  }

  .release-card:hover {
    box-shadow: 0 8px 24px rgba(23, 23, 23, 0.1);
    transform: translateY(-2px);
  }

  .release-card a {
    display: grid;
    gap: 10px;
    min-height: 190px;
    padding: 18px;
    text-decoration: none;
  }

  .cover-swatch,
  .cover-image {
    width: 64px;
    height: 64px;
    border-radius: 6px;
    object-fit: cover;
    background: var(--gold);
  }

  .release-card h3 {
    margin: 0;
    font-size: 1.3rem;
  }

  .release-card p {
    margin: 0;
    color: var(--muted);
  }

  .release-card-rich {
    background: #d4d4d0;
  }

  .release-card-rich a {
    grid-template-rows: auto auto auto 1fr auto;
    min-height: 370px;
    gap: 12px;
  }

  .release-card-rich .cover-image {
    width: 100%;
    height: auto;
    aspect-ratio: 1;
    border-radius: 2px;
  }

  .release-card-artist {
    color: var(--muted);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .release-card-rich p {
    display: -webkit-box;
    overflow: hidden;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 5;
    font-size: 0.92rem;
  }

  .release-more {
    justify-self: end;
    color: #455fd6;
    font-size: 0.86rem;
    font-style: italic;
  }
</style>

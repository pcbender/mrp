---
import ReleaseBrowser from "./ReleaseBrowser.astro";
import type { ReleaseCardModel } from "../lib/catalog";

interface Props {
  artistName: string;
  releases: ReleaseCardModel[];
}

const { artistName, releases } = Astro.props;
---
<section class="artist-release-list page-grid centered-page">
  <p class="eyebrow artist-releases-eyebrow">Releases</p>
  {releases.length > 0 ? (
    <ReleaseBrowser releases={releases} rich />
  ) : (
    <p class="empty-state">No public releases yet.</p>
  )}
</section>

<style>
  .artist-release-list {
    display: grid;
    gap: 18px;
  }

  .artist-releases-eyebrow {
    font-size: 1.6rem;
    letter-spacing: 0.08em;
    text-align: center;
  }
</style>

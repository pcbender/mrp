---
import { postDate, postExcerpt, postImage, postUrl } from "../lib/posts.js";

interface Props {
  post: Record<string, any>;
}

const { post } = Astro.props;
const href = postUrl(post);
const image = postImage(post);
const date = postDate(post);
const excerpt = postExcerpt(post);
---
<article class="post-card">
  <a class="post-card-media" href={href} aria-label={post.title}>
    <img src={image} alt="" loading="lazy" />
  </a>
  <div class="post-card-copy">
    <p class="post-card-meta">{post.author ?? 'Maricopa Records'} &middot; {date}</p>
    <h2><a href={href}>{post.title}</a></h2>
    <p>{excerpt}</p>
    <a class="post-card-more" href={href}>Read more</a>
  </div>
</article>

<style>
  .post-card {
    display: grid;
    align-content: start;
    gap: 18px;
    min-width: 0;
  }

  .post-card-media {
    display: block;
    overflow: hidden;
    border-radius: 8px;
    background: var(--green);
    aspect-ratio: 16 / 10;
  }

  .post-card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 180ms ease;
  }

  .post-card-media:hover img,
  .post-card-media:focus-visible img {
    transform: scale(1.03);
  }

  .post-card-copy {
    display: grid;
    gap: 10px;
  }

  .post-card-meta {
    margin: 0;
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  h2 {
    margin: 0;
    font-size: clamp(1.1rem, 2.1vw, 1.55rem);
    line-height: 1.18;
    letter-spacing: 0;
  }

  h2 a,
  .post-card-more {
    text-decoration: none;
    transition: color var(--transition);
  }

  h2 a:hover {
    color: var(--red);
  }

  .post-card-copy > p:not(.post-card-meta) {
    margin: 0;
    color: var(--muted);
  }

  .post-card-more {
    justify-self: start;
    color: var(--red);
    font-size: 0.86rem;
    font-weight: 700;
  }

  .post-card-more:hover {
    color: var(--ink);
  }
</style>

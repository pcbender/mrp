---
import ImageLoop from "./ImageLoop.astro";
import type { ArtistCardModel } from "../lib/catalog";

interface Props {
  artists: ArtistCardModel[];
  variant?: "split" | "media";
}

const { artists, variant = "split" } = Astro.props;
const items = artists.map((artist) => ({
  title: artist.name,
  subtitle: artist.summary,
  href: artist.href,
  image: artist.image,
  kicker: "Artist",
}));
---
<ImageLoop eyebrow="Roster" title="Our Artists" ariaLabel="Artist carousel" items={items} variant={variant} />

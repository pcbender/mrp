---
import ImageLoop from "./ImageLoop.astro";
import type { ReleaseCardModel } from "../lib/catalog";

interface Props {
  releases: ReleaseCardModel[];
  variant?: "split" | "media";
}

const { releases, variant = "split" } = Astro.props;
const items = releases.map((release) => ({
  title: release.title,
  subtitle: release.artistName,
  href: release.href,
  image: release.coverImage,
  kicker: release.releaseType,
}));
---
<ImageLoop eyebrow="Latest" title="Latest releases" ariaLabel="Latest releases carousel" items={items} variant={variant} />

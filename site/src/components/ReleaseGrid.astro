---
import ReleaseCard from "./ReleaseCard.astro";
import type { ReleaseCardModel } from "../lib/catalog";
import { getEntry } from "astro:content";

interface Props {
  releases: ReleaseCardModel[];
  rich?: boolean;
}

const { releases, rich = false } = Astro.props;

const summaries = await Promise.all(
  releases.map(async (release) => {
    if (release.summary) return release.summary;
    const reviewEntry = await getEntry("reviews", `${release.artistId}--${release.slug}`).catch(() => null);
    return reviewEntry?.data.impression || reviewEntry?.data.summary || "";
  })
);
---
<div class="card-grid release-grid">
  {releases.map((release, i) => (
    <ReleaseCard
      title={release.title}
      titleAscii={release.titleAscii}
      artist={release.artistName}
      href={release.href}
      type={release.releaseType}
      releaseDate={release.releaseDate}
      coverImage={release.coverImage}
      summary={summaries[i]}
      rich={rich}
    />
  ))}
</div>

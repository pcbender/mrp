---
const nav = [
  { href: "/artists/", label: "Artists" },
  { href: "/releases/", label: "Releases" },
  { href: "/licensing-custom-songs/", label: "Licensing & Custom Songs" },
  { href: "/posts/", label: "Posts" },
  { href: "/about-us/", label: "About" },
  { href: "/contact/", label: "Contact" }
];
const { pathname } = Astro.url;
const isActive = (href: string) => pathname === href || pathname.startsWith(href);
---
<header class="site-header">
  <div class="site-header-inner">
    <a class="brand" href="/">
      <img src="/assets/maricopa-logo-header.png" alt="Maricopa Records" width="363" height="132" />
    </a>
    <nav aria-label="Primary navigation">
      {nav.map((item) => (
        <a href={item.href} class={isActive(item.href) ? 'active' : undefined}>{item.label}</a>
      ))}
    </nav>
  </div>
</header>

---
import Breadcrumbs from "./Breadcrumbs.astro";
import Lyrics from "./Lyrics.astro";
import StreamingLinks from "./StreamingLinks.astro";
import { releaseCoverUrl } from "../lib/content.js";
import { releaseSocialLinks, trackStreamingLinks } from "../lib/catalog";
import { getEntry } from "astro:content";

interface Props {
  release: any;
  artist?: any;
}

const { release, artist } = Astro.props;
const artistName = artist?.name || release.artist_id;
const artistHref = `/artists/${release.artist_id}/`;
const copyBlocks = releaseCopyBlocks(release);
const streamingLinks = releaseSocialLinks(release);
const coverUrl = releaseCoverUrl(release);
const hasCredits = Boolean(release.credits?.songwriter || release.credits?.producer || release.credits?.mastering);

const reviewId = release.song?.slug
  ? `${release.artist_id}--${release.song.slug}`   // single
  : `${release.artist_id}--${release.slug}`;        // album / EP
const reviewEntry = await getEntry("reviews", reviewId).catch(() => null);
const { Content: ReviewContent } = reviewEntry ? await reviewEntry.render() : {};

function releaseCopyBlocks(release: any) {
  const source = String(release.description || release.summary || "").split(/\n## Tracks\b/i)[0];
  return source
    .replace(/!\[[^\]]*\]\([^)]+\)/g, "")
    .replace(/\[([^\]]*)\]\([^)]+\)/g, "$1")
    .split(/\n{2,}/)
    .map((block) => block.trim())
    .filter(Boolean)
    .filter((block) => !block.startsWith("## "))
    .map(cleanMarkdownText)
    .filter(Boolean);
}

function cleanMarkdownText(value: string) {
  return String(value)
    .replace(/\*\*([^*]+)\*\*/g, "$1")
    .replace(/__([^_]+)__/g, "$1")
    .replace(/\*([^*]+)\*/g, "$1")
    .replace(/_([^_]+)_/g, "$1 ")
    .replace(/\s+([,.;:!?])/g, "$1")
    .replace(/\s+/g, " ")
    .trim();
}
---
<article class="release-landing">
  <header class="release-hero" style={`--release-hero-image: url("${coverUrl}")`}>
    <h1>{release.title}</h1>
    <Breadcrumbs items={[
      { label: "Artists", href: "/artists/" },
      { label: artistName, href: artistHref },
      { label: release.title },
    ]} />
  </header>

  <section class="release-feature">
    <div class="release-copy">
      <p class="eyebrow">{release.release_type}</p>
      <h2>{release.title}</h2>
      {copyBlocks.map((block) => <p>{block}</p>)}
      {reviewEntry && (
        <div class="track-review">
          {reviewEntry.data.impression && (
            <p class="impression">{reviewEntry.data.impression}</p>
          )}
          {ReviewContent && (
            <details class="review-more">
              <summary>More</summary>
              <div class="review-body"><ReviewContent /></div>
            </details>
          )}
        </div>
      )}
      {release.song?.preview_audio && (
        <audio class="sample-player" controls src={release.song.preview_audio}>
          <source src={release.song.preview_audio} type="audio/mpeg" />
        </audio>
      )}
      <StreamingLinks links={streamingLinks} />
    </div>
    <img src={coverUrl} alt="" width="800" height="800" />
  </section>

  {release.tracks?.length > 0 && (
    <section class="track-list">
      <div class="section-heading">
        <p class="eyebrow">Tracks</p>
        <h2>{release.release_type === "ep" ? "EP tracks" : "Album tracks"}</h2>
      </div>
      <ol>
        {release.tracks.map((track: any) => (
          <li>
            <span>{track.number}</span>
            <strong><a href={`/releases/${release.slug}/${track.slug}/`}>{track.title}</a></strong>
            <StreamingLinks links={trackStreamingLinks(track)} compact showMissing label={`${track.title} streaming links`} />
          </li>
        ))}
      </ol>
    </section>
  )}

  {release.song && (release.song.lyrics_text || release.song.instrumental) && (
    <section class="lyrics">
      <h2>Lyrics</h2>
      <Lyrics lyricsText={release.song.lyrics_text} instrumental={release.song.instrumental} />
      {release.song.lyrics_text && (
        <footer class="lyrics-footer">
          <p>Written by {release.credits?.lyrics || artistName}</p>
          <p>Lyrics © {release.release_date?.slice(0, 4)} Maricopa Publishing. All rights reserved.</p>
          <p>Published by Maricopa Publishing. Displayed by permission.</p>
          <p>For licensing: <a href="/licensing-custom-songs/music-licensing">maricoparecords.com/licensing</a></p>
        </footer>
      )}
    </section>
  )}

  {hasCredits && (
    <section class="prose">
      <h2>Credits</h2>
      {release.credits?.songwriter && <p>Songwriter: {release.credits.songwriter}</p>}
      {release.credits?.producer && <p>Producer: {release.credits.producer}</p>}
      {release.credits?.mastering && <p>Mastering: {release.credits.mastering}</p>}
    </section>
  )}
</article>

<style>
  .release-hero {
    min-height: 150px;
    display: grid;
    place-items: center;
    padding: clamp(24px, 4vw, 44px) clamp(20px, 4vw, 56px);
    color: #ffffff;
    text-align: center;
    background:
      linear-gradient(rgba(17, 17, 17, 0.54), rgba(17, 17, 17, 0.58)),
      var(--release-hero-image),
      var(--green);
    background-position: center;
    background-size: cover;
  }

  .release-hero h1 {
    margin: 0;
    max-width: 980px;
    font-weight: 400;
    font-size: clamp(2rem, 5vw, 4.2rem);
    line-height: 1;
    letter-spacing: 0;
  }

  .release-hero :global(.breadcrumbs) {
    color: rgba(255, 255, 255, 0.78);
  }

  .release-hero :global(.breadcrumbs li + li::before) {
    color: rgba(255, 255, 255, 0.45);
  }

  .release-feature {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(320px, 1.05fr);
    gap: clamp(28px, 5vw, 72px);
    align-items: center;
    padding: clamp(48px, 7vw, 88px) clamp(20px, 4vw, 56px);
    width: min(100% - clamp(40px, 8vw, 112px), 1200px);
    margin: clamp(24px, 4vw, 48px) auto;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    box-shadow: 0 10px 28px rgba(23, 23, 23, 0.08);
  }

  .release-feature > img {
    width: 100%;
    aspect-ratio: 1;
    max-height: 560px;
    border: 1px solid var(--line);
    border-radius: 8px;
    object-fit: cover;
    background: var(--panel);
  }

  .release-copy {
    display: grid;
    gap: 18px;
    justify-items: center;
    text-align: center;
  }

  .release-copy h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.4rem);
    line-height: 1;
    letter-spacing: 0;
  }

  .release-copy p {
    margin: 0;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .sample-player {
    width: 100%;
    max-width: 380px;
  }

  .track-review {
    display: grid;
    gap: 12px;
    width: 100%;
    text-align: left;
  }

  .impression {
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
    font-style: italic;
    line-height: 1.7;
  }

  .review-body {
    font-size: 1rem;
    line-height: 1.75;
  }

  .review-body :global(p) {
    margin: 0 0 1em;
  }

  .review-more {
    width: 100%;
  }

  .review-more summary {
    display: inline-block;
    cursor: pointer;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--muted);
    list-style: none;
    user-select: none;
  }

  .review-more summary::-webkit-details-marker {
    display: none;
  }

  .review-more[open] summary {
    margin-bottom: 12px;
  }

  .track-list {
    display: grid;
    gap: 28px;
    width: min(100% - clamp(40px, 8vw, 112px), 980px);
    margin: 0 auto;
    padding: clamp(20px, 4vw, 42px) 0 clamp(42px, 7vw, 84px);
  }

  .track-list ol {
    display: grid;
    gap: 10px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  .track-list li {
    display: grid;
    grid-template-columns: 4ch minmax(0, 1fr) minmax(130px, auto);
    gap: 20px;
    align-items: center;
    padding: 14px 8px;
    border-bottom: 1px solid var(--line);
    border-radius: 4px;
    transition: background var(--transition);
  }

  .track-list li:hover {
    background: rgba(212, 173, 53, 0.06);
  }

  .track-list li a {
    text-decoration: none;
    transition: color var(--transition);
  }

  .track-list li a:hover {
    color: var(--red);
  }

  .track-list span {
    color: var(--muted);
    font-weight: 700;
    font-size: 0.85rem;
    text-align: center;
  }

  .lyrics {
    display: grid;
    gap: 16px;
    width: min(100% - clamp(40px, 8vw, 112px), 720px);
    margin: 0 auto;
    padding: clamp(20px, 4vw, 42px) 0 clamp(42px, 7vw, 84px);
  }

  .lyrics-footer {
    margin-top: clamp(24px, 4vw, 40px);
    padding-top: 20px;
    border-top: 1px solid var(--line);
  }

  .lyrics-footer p {
    margin: 0 0 4px;
    color: var(--muted);
    font-size: 0.8rem;
    line-height: 1.5;
  }

  .lyrics-footer a {
    color: var(--muted);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .lyrics-footer a:hover {
    color: var(--ink);
  }

  @media (max-width: 760px) {
    .release-feature {
      grid-template-columns: 1fr;
    }

    .release-copy {
      justify-items: start;
      text-align: left;
    }

    .track-list {
      grid-template-columns: 1fr;
    }
  }
</style>

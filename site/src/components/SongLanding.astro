---
import Breadcrumbs from "./Breadcrumbs.astro";
import Lyrics from "./Lyrics.astro";
import StreamingLinks from "./StreamingLinks.astro";
import { releaseCoverUrl } from "../lib/content.js";
import { trackStreamingLinks } from "../lib/catalog";
import { getEntry } from "astro:content";

interface Props {
  release: any;
  track: any;
  artist?: any;
}

const { release, track, artist } = Astro.props;
const artistName = artist?.name || release.artist_id;
const artistHref = `/artists/${release.artist_id}/`;
const releaseHref = `/releases/${release.slug}/`;
const streamingLinks = trackStreamingLinks(track);
const coverUrl = releaseCoverUrl(release);
const trackId = `${release.artist_id}--${track.slug}`;
const reviewEntry = await getEntry("reviews", trackId);
const { Content: ReviewContent } = reviewEntry ? await reviewEntry.render() : {};

const sortedTracks = release.tracks
  ? [...release.tracks].sort((a: any, b: any) => (a.number ?? 0) - (b.number ?? 0))
  : [];
const trackIndex = sortedTracks.findIndex((t: any) => t.slug === track.slug);
const prevTrack = trackIndex > 0 ? sortedTracks[trackIndex - 1] : null;
const nextTrack = trackIndex < sortedTracks.length - 1 ? sortedTracks[trackIndex + 1] : null;
---
<article class="release-landing">
  <header class="release-hero" style={`--release-hero-image: url("${coverUrl}")`}>
    <h1>{track.title}</h1>
    <Breadcrumbs items={[
      { label: "Artists", href: "/artists/" },
      { label: artistName, href: artistHref },
      { label: release.title, href: releaseHref },
      { label: track.title },
    ]} />
  </header>

  <section class="release-feature">
    <div class="release-copy">
      <p class="eyebrow">From {release.title}</p>
      <h2>{track.title}</h2>
      {reviewEntry && (
        <div class="track-review">
          {reviewEntry.data.impression && (
            <p class="impression">{reviewEntry.data.impression}</p>
          )}
          {ReviewContent && (
            <details class="review-more">
              <summary>More</summary>
              <div class="review-body"><ReviewContent /></div>
            </details>
          )}
        </div>
      )}
      {track.preview_audio && (
        <audio class="sample-player" controls src={track.preview_audio}>
          <source src={track.preview_audio} type="audio/mpeg" />
        </audio>
      )}
      <StreamingLinks links={streamingLinks} showMissing />
    </div>
    <img src={coverUrl} alt="" width="800" height="800" />
  </section>

  {sortedTracks.length > 1 && (
    <nav class="track-nav" aria-label="Album track navigation">
      {prevTrack ? (
        <a href={`/releases/${release.slug}/${prevTrack.slug}/`} class="track-nav-link track-nav-prev">
          <span class="track-nav-arrow" aria-hidden="true">&#8592;</span>
          <span class="track-nav-info">
            <span class="track-nav-label">Previous</span>
            <span class="track-nav-title">{prevTrack.title}</span>
          </span>
        </a>
      ) : <span class="track-nav-link track-nav-prev track-nav-disabled" aria-hidden="true" />}
      <a href={releaseHref} class="track-nav-album">{release.title}</a>
      {nextTrack ? (
        <a href={`/releases/${release.slug}/${nextTrack.slug}/`} class="track-nav-link track-nav-next">
          <span class="track-nav-info">
            <span class="track-nav-label">Next</span>
            <span class="track-nav-title">{nextTrack.title}</span>
          </span>
          <span class="track-nav-arrow" aria-hidden="true">&#8594;</span>
        </a>
      ) : <span class="track-nav-link track-nav-next track-nav-disabled" aria-hidden="true" />}
    </nav>
  )}

  {track.lyrics_text && (
    <section class="lyrics">
      <h2>Lyrics</h2>
      <Lyrics lyricsText={track.lyrics_text} instrumental={track.instrumental} />
      {track.lyrics_text && (
        <footer class="lyrics-footer">
          <p>Written by {release.credits?.lyrics || artistName}</p>
          <p>Lyrics © {release.release_date?.slice(0, 4)} Maricopa Publishing. All rights reserved.</p>
          <p>Published by Maricopa Publishing. Displayed by permission.</p>
          <p>For licensing: <a href="/licensing-custom-songs/music-licensing">maricoparecords.com/licensing</a></p>
        </footer>
      )}
    </section>
  )}

</article>

<style>
  .release-hero {
    min-height: 150px;
    display: grid;
    place-items: center;
    padding: clamp(24px, 4vw, 44px) clamp(20px, 4vw, 56px);
    color: #ffffff;
    text-align: center;
    background:
      linear-gradient(rgba(17, 17, 17, 0.54), rgba(17, 17, 17, 0.58)),
      var(--release-hero-image),
      var(--green);
    background-position: center;
    background-size: cover;
  }

  .release-hero h1 {
    margin: 0;
    max-width: 980px;
    font-weight: 400;
    font-size: clamp(2rem, 5vw, 4.2rem);
    line-height: 1;
    letter-spacing: 0;
  }

  .release-hero :global(.breadcrumbs) {
    color: rgba(255, 255, 255, 0.78);
  }

  .release-hero :global(.breadcrumbs li + li::before) {
    color: rgba(255, 255, 255, 0.45);
  }

  .release-feature {
    display: grid;
    grid-template-columns: minmax(0, 0.95fr) minmax(320px, 1.05fr);
    gap: clamp(28px, 5vw, 72px);
    align-items: center;
    padding: clamp(48px, 7vw, 88px) clamp(20px, 4vw, 56px);
    width: min(100% - clamp(40px, 8vw, 112px), 1200px);
    margin: clamp(24px, 4vw, 48px) auto;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
    box-shadow: 0 10px 28px rgba(23, 23, 23, 0.08);
  }

  .release-feature > img {
    width: 100%;
    aspect-ratio: 1;
    max-height: 560px;
    border: 1px solid var(--line);
    border-radius: 8px;
    object-fit: cover;
    background: var(--panel);
  }

  .release-copy {
    display: grid;
    gap: 18px;
    justify-items: center;
    text-align: center;
  }

  .release-copy h2 {
    margin: 0;
    font-size: clamp(2rem, 4vw, 3.4rem);
    line-height: 1;
    letter-spacing: 0;
  }

  .release-copy p {
    margin: 0;
    color: var(--muted);
    font-size: 1.08rem;
  }

  .sample-player {
    width: 100%;
    max-width: 380px;
  }

  .track-nav {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    gap: 12px;
    width: min(100% - clamp(40px, 8vw, 112px), 1200px);
    margin: 0 auto clamp(32px, 5vw, 64px);
    padding: 16px clamp(16px, 3vw, 32px);
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
  }

  .track-nav-link {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 8px;
    border-radius: 6px;
    text-decoration: none;
    color: var(--ink);
    transition: background 0.15s;
  }

  .track-nav-link:hover {
    background: var(--line);
  }

  .track-nav-prev { justify-content: flex-start; }
  .track-nav-next { justify-content: flex-end; }

  .track-nav-disabled {
    pointer-events: none;
    opacity: 0;
  }

  .track-nav-arrow {
    font-size: 1.4rem;
    flex-shrink: 0;
    color: var(--muted);
  }

  .track-nav-info {
    display: flex;
    flex-direction: column;
  }

  .track-nav-prev .track-nav-info { align-items: flex-start; }
  .track-nav-next .track-nav-info { align-items: flex-end; }

  .track-nav-label {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--muted);
  }

  .track-nav-title {
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--ink);
  }

  .track-nav-album {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--muted);
    text-decoration: none;
    text-align: center;
    white-space: nowrap;
    padding: 4px 8px;
    border-radius: 4px;
    transition: color 0.15s;
  }

  .track-nav-album:hover { color: var(--ink); }

  @media (max-width: 560px) {
    .track-nav { grid-template-columns: 1fr 1fr; grid-template-rows: auto auto; }
    .track-nav-album { grid-column: 1 / -1; grid-row: 2; border-top: 1px solid var(--line); padding-top: 12px; }
  }

  .lyrics {
    display: grid;
    gap: 16px;
    width: min(100% - clamp(40px, 8vw, 112px), 720px);
    margin: 0 auto;
    padding: clamp(20px, 4vw, 42px) 0 clamp(42px, 7vw, 84px);
  }

  .lyrics-footer {
    margin-top: clamp(24px, 4vw, 40px);
    padding-top: 20px;
    border-top: 1px solid var(--line);
  }

  .lyrics-footer p {
    margin: 0 0 4px;
    color: var(--muted);
    font-size: 0.8rem;
    line-height: 1.5;
  }

  .lyrics-footer a {
    color: var(--muted);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .lyrics-footer a:hover {
    color: var(--ink);
  }

  .track-review {
    display: grid;
    gap: 12px;
    width: 100%;
    text-align: left;
  }

  .impression {
    margin: 0;
    color: var(--muted);
    font-size: 0.95rem;
    font-style: italic;
    line-height: 1.7;
  }

  .review-body {
    font-size: 1rem;
    line-height: 1.75;
  }

  .review-body :global(p) {
    margin: 0 0 1em;
  }

  .review-more {
    width: 100%;
  }

  .review-more summary {
    display: inline-block;
    cursor: pointer;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--muted);
    list-style: none;
    user-select: none;
  }

  .review-more summary::-webkit-details-marker {
    display: none;
  }

  .review-more[open] summary {
    margin-bottom: 12px;
  }

  @media (max-width: 760px) {
    .release-feature {
      grid-template-columns: 1fr;
    }

    .release-copy {
      justify-items: start;
      text-align: left;
    }
  }
</style>

---
import SEOHead from "../components/SEOHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getCloneHeadForPath, renderCloneHtml } from "../lib/content.js";

interface Props {
  title: string;
  description: string;
  path: string;
}

const { title, description, path } = Astro.props;
const head = getCloneHeadForPath(path);
const shared = head.shared || {};
const page = head.page || {};
const stylesheets = [...(shared.stylesheets || []), ...(page.stylesheets || [])];
const preloads = [...(shared.preloads || []), ...(page.preloads || [])];
const scripts = [...(shared.scripts || []), ...(page.scripts || [])];
const inlineStyles = [...(shared.inline_styles || []), ...(page.inline_styles || [])];
const staticUrl = (value) => (value ? renderCloneHtml(value) : value);
---
<!doctype html>
<html lang="en">
  <head>
    <SEOHead title={title} description={description} />
    {preloads.map((item) => (
      <link rel={item.rel || "preload"} href={item.local_path || staticUrl(item.href)} as={item.as || undefined} />
    ))}
    {stylesheets.map((item) => (
      <link rel="stylesheet" id={item.id || undefined} href={item.local_path || staticUrl(item.href)} media={item.media || undefined} />
    ))}
    {inlineStyles.map((item) => <style set:html={renderCloneHtml(item.content)} />)}
    {scripts.map((item) => (
      <script src={item.local_path || staticUrl(item.src)} type={item.type || undefined} defer={item.defer || undefined} async={item.async || undefined}></script>
    ))}
  </head>
  <body class="wp-clone-body">
    <Header />
    <main class="wp-clone-main">
      <slot />
    </main>
    <Footer />
  </body>
</html>

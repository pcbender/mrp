---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import SEOHead from "../components/SEOHead.astro";

interface Props {
  title: string;
  description: string;
  paneled?: boolean;
}

const { title, description, paneled = false } = Astro.props;
---
<!doctype html>
<html lang="en">
  <head>
    <SEOHead title={title} description={description} />
  </head>
  <body>
    <Header />
    <main>
      {paneled ? <div class="main-panel"><slot /></div> : <slot />}
    </main>
    <Footer />
  </body>
</html>

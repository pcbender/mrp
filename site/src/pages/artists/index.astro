---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArtistCard from "../../components/ArtistCard.astro";
import { artistReleaseCount, getArtists } from "../../lib/content.js";

const artists = getArtists();
---
<BaseLayout title="Artists | Maricopa Records" description="Artists on Maricopa Records.">
  <section class="page-heading">
    <p class="eyebrow">Artists</p>
    <h1>Maricopa Records roster</h1>
  </section>
  <section class="card-grid page-grid">
    {artists.map((artist) => (
      <ArtistCard
        name={artist.name}
        href={`/artists/${artist.id}/`}
        summary={`${artistReleaseCount(artist.id)} public release${artistReleaseCount(artist.id) === 1 ? "" : "s"}`}
        image={artist.image}
      />
    ))}
  </section>
</BaseLayout>

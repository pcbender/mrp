---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ArtistReleaseList from "../../components/ArtistReleaseList.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import StreamingLinks from "../../components/StreamingLinks.astro";
import { getArtistById, getArtists } from "../../lib/content.js";
import { artistStreamingLinks, releasesForArtist } from "../../lib/catalog";

export function getStaticPaths() {
  return getArtists().map((artist) => ({ params: { slug: artist.id } }));
}

const artist = getArtistById(Astro.params.slug);
const releases = releasesForArtist(artist.id);
const links = artistStreamingLinks(artist);
const bioBlocks = String(artist.bio_long || "")
  .split("## Releases")[0]
  .replace(/!\[[^\]]*\]\([^)]+\)/g, "")
  .replace(/\[[^\]]*\]\([^)]+\)/g, "")
  .split(/\n{2,}/)
  .map((block) => block.trim())
  .filter(Boolean)
  .filter((block) => block !== `## ${artist.name}`)
  .map((block) => {
    if (block.startsWith("## ")) {
      return { tag: "h2", text: cleanMarkdownText(block.slice(3)) };
    }
    if (block.startsWith("### ")) {
      return { tag: "h3", text: cleanMarkdownText(block.slice(4)) };
    }
    return { tag: "p", text: cleanMarkdownText(block.replace(/\n+/g, " ")) };
  });

function cleanMarkdownText(value: string) {
  return String(value)
    .replace(/\*\*([^*]+)\*\*/g, "$1")
    .replace(/__([^_]+)__/g, "$1")
    .replace(/\*([^*]+)\*/g, "$1")
    .replace(/_([^_]+)_/g, "$1")
    .replace(/\s+([,.;:!?])/g, "$1")
    .replace(/\s+/g, " ")
    .trim();
}

---
<BaseLayout paneled={true} title={`${artist.name} | Maricopa Records`} description={artist.bio_short || `${artist.name} on Maricopa Records.`}>
  <header class="artist-hero" style={`--artist-hero-image: url("${artist.image || "/assets/maricopa-mark.svg"}")`}>
    <h1>{artist.name}</h1>
    <Breadcrumbs items={[
      { label: "Artists", href: "/artists/" },
      { label: artist.name },
    ]} />
  </header>

  <section class="artist-profile-card">
    <div>
      <p class="eyebrow">Artist</p>
      <h1>{artist.name}</h1>
      {bioBlocks.map((block) =>
        block.tag === "h2" ? <h2>{block.text}</h2> : block.tag === "h3" ? <h3>{block.text}</h3> : <p>{block.text}</p>
      )}
      <StreamingLinks links={links} />
    </div>
    <img src={artist.image || "/assets/maricopa-mark.svg"} alt="" width="320" height="320" />
  </section>
  <ArtistReleaseList artistName={artist.name} releases={releases} />
</BaseLayout>

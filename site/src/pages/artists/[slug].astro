---
import BaseLayout from "../../layouts/BaseLayout.astro";
import CloneLayout from "../../layouts/CloneLayout.astro";
import ArtistReleaseList from "../../components/ArtistReleaseList.astro";
import SocialLinks from "../../components/SocialLinks.astro";
import {
  cloneDescription,
  getArtistById,
  getArtists,
  getCloneByPath,
  renderCloneHtml
} from "../../lib/content.js";
import { releasesForArtist } from "../../lib/catalog";

export function getStaticPaths() {
  return getArtists().map((artist) => ({ params: { slug: artist.id } }));
}

const artist = getArtistById(Astro.params.slug);
const releases = releasesForArtist(artist.id);
const links = Object.entries(artist.links || {})
  .filter((entry): entry is [string, string] => Boolean(entry[1]))
  .map(([label, href]) => ({ label: label.replaceAll("_", " "), href }));
const clonePath = `/artists/${artist.id}/`;
const clone = getCloneByPath(clonePath);
const cloneHtml = clone ? renderCloneHtml(clone.content_html) : "";
---
{clone ? (
  <CloneLayout title={`${clone.title} | Maricopa Records`} description={cloneDescription(clone)} path={clonePath}>
    <article class="wp-clone-content" data-clone-kind={clone.kind}>
      <div class="wp-content" set:html={cloneHtml} />
    </article>
  </CloneLayout>
) : (
  <BaseLayout title={`${artist.name} | Maricopa Records`} description={artist.bio_short || `${artist.name} on Maricopa Records.`}>
    <section class="page-heading artist-heading">
      <img src={artist.image || "/assets/maricopa-mark.svg"} alt="" width="96" height="96" />
      <p class="eyebrow">Artist</p>
      <h1>{artist.name}</h1>
      <p>{artist.bio_short}</p>
      <SocialLinks links={links} />
    </section>
    <ArtistReleaseList artistName={artist.name} releases={releases} />
  </BaseLayout>
)}

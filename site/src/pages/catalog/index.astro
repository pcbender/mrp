---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getArtists, getVisibleReleases } from "../../lib/content.js";

const artistMap = new Map(getArtists().map((a) => [a.id, a.name]));

// Flatten all visible releases to individual track rows
const songs = getVisibleReleases().flatMap((release) => {
  const artistName = artistMap.get(release.artist_id) || release.artist_id;
  const releaseDate = release.release_date || "";
  const upc = release.upc || "";

  const releaseType = release.release_type || "";

  if (release.model === "song" && release.song) {
    return [{
      artistName,
      artistId: release.artist_id,
      title: release.song.title || release.title,
      isrc: release.song.isrc || "",
      releaseDate,
      releaseType,
      upc,
      href: `/releases/${release.slug}/`,
    }];
  }

  return (release.tracks || []).map((track) => ({
    artistName,
    artistId: release.artist_id,
    title: track.title,
    isrc: track.isrc || "",
    releaseDate,
    releaseType,
    upc,
    href: `/releases/${release.slug}/${track.slug}/`,
  }));
}).sort((a, b) =>
  b.releaseDate.localeCompare(a.releaseDate) || a.title.localeCompare(b.title)
);

const artists = Array.from(new Set(songs.map((s) => s.artistName))).sort((a, b) => a.localeCompare(b));
const types = Array.from(new Set(songs.map((s) => s.releaseType).filter(Boolean))).sort();
const years = Array.from(new Set(songs.map((s) => s.releaseDate.slice(0, 4)).filter(Boolean))).sort().reverse();
---

<BaseLayout paneled={true} title="Catalog | Maricopa Records" description="Full song catalog for Maricopa Records — titles, ISRCs, and release data.">
  <section class="page-heading centered-page">
    <p class="eyebrow">Catalog</p>
    <p>Every song in the Maricopa Records catalog</p>
  </section>
  <section class="page-grid centered-page">
  <div class="catalog-browser" data-catalog-browser>
      <form class="release-browser-controls" data-catalog-controls>
        <label class="release-browser-search">
          <span>Search</span>
          <input type="search" name="search" autocomplete="off" placeholder="Title or artist" data-catalog-search />
        </label>
        {types.length > 1 && (
          <label>
            <span>Type</span>
            <select name="type" data-catalog-type>
              <option value="">All types</option>
              {types.map((t) => <option value={t}>{t}</option>)}
            </select>
          </label>
        )}
        {artists.length > 1 && (
          <label>
            <span>Artist</span>
            <select name="artist" data-catalog-artist>
              <option value="">All artists</option>
              {artists.map((a) => <option value={a}>{a}</option>)}
            </select>
          </label>
        )}
        {years.length > 1 && (
          <label>
            <span>Year</span>
            <select name="year" data-catalog-year>
              <option value="">All years</option>
              {years.map((y) => <option value={y}>{y}</option>)}
            </select>
          </label>
        )}
        <label>
          <span>Sort</span>
          <select name="sort" data-catalog-sort>
            <option value="newest">Newest first</option>
            <option value="oldest">Oldest first</option>
            <option value="title">Title A-Z</option>
            <option value="artist">Artist A-Z</option>
          </select>
        </label>
        <label>
          <span>Show</span>
          <select name="page-size" data-catalog-page-size>
            <option value="25" selected>25</option>
            <option value="50">50</option>
            <option value="100">100</option>
            <option value="0">All</option>
          </select>
        </label>
      </form>

      <div class="release-browser-summary">
        <span data-catalog-count>{songs.length} song{songs.length === 1 ? "" : "s"}</span>
        <div class="release-browser-pages">
          <button class="button" type="button" data-catalog-prev>Previous</button>
          <span data-catalog-page-status>Page 1</span>
          <button class="button" type="button" data-catalog-next>Next</button>
        </div>
      </div>

      <div class="catalog-table-wrap">
        <table class="catalog-table">
          <thead>
            <tr>
              <th>Artist</th>
              <th>Title</th>
              <th>ISRC</th>
              <th>Release Date</th>
              <th>UPC</th>
            </tr>
          </thead>
          <tbody data-catalog-tbody>
            {songs.map((song) => (
              <tr
                data-catalog-row
                data-catalog-search={`${song.title} ${song.artistName}`.toLowerCase()}
                data-catalog-type={song.releaseType}
                data-catalog-artist={song.artistName}
                data-catalog-date={song.releaseDate}
                data-catalog-title={song.title.toLowerCase()}
              >
                <td>{song.artistName}</td>
                <td><a href={song.href}>{song.title}</a></td>
                <td class="catalog-mono">{song.isrc || "—"}</td>
                <td class="catalog-mono">{song.releaseDate || "—"}</td>
                <td class="catalog-mono">{song.upc || "—"}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
      <p class="empty-state release-browser-empty" data-catalog-empty hidden>No songs match those controls.</p>
    </div>
  </section>
</BaseLayout>

<script>
  const browser = document.querySelector("[data-catalog-browser]");
  if (browser) {
    const tbody = browser.querySelector("[data-catalog-tbody]");
    const rows = Array.from(browser.querySelectorAll("[data-catalog-row]"));
    const search = browser.querySelector("[data-catalog-search]");
    const type = browser.querySelector("[data-catalog-type]");
    const artist = browser.querySelector("[data-catalog-artist]");
    const year = browser.querySelector("[data-catalog-year]");
    const sort = browser.querySelector("[data-catalog-sort]");
    const pageSize = browser.querySelector("[data-catalog-page-size]");
    const prev = browser.querySelector("[data-catalog-prev]");
    const next = browser.querySelector("[data-catalog-next]");
    const count = browser.querySelector("[data-catalog-count]");
    const pageStatus = browser.querySelector("[data-catalog-page-status]");
    const empty = browser.querySelector("[data-catalog-empty]");

    let page = 1;

    function matches(row) {
      const q = (search.value || "").toLowerCase().trim();
      const sel_type = type ? type.value : "";
      const sel_artist = artist ? artist.value : "";
      const sel_year = year ? year.value : "";
      if (q && !row.dataset.catalogSearch.includes(q)) return false;
      if (sel_type && row.dataset.catalogType !== sel_type) return false;
      if (sel_artist && row.dataset.catalogArtist !== sel_artist) return false;
      if (sel_year && !row.dataset.catalogDate.startsWith(sel_year)) return false;
      return true;
    }

    function compareRows(a, b) {
      const mode = sort.value;
      if (mode === "oldest") return (a.dataset.catalogDate || "").localeCompare(b.dataset.catalogDate || "");
      if (mode === "title") return (a.dataset.catalogTitle || "").localeCompare(b.dataset.catalogTitle || "");
      if (mode === "artist") {
        const o = (a.dataset.catalogArtist || "").localeCompare(b.dataset.catalogArtist || "");
        return o !== 0 ? o : (a.dataset.catalogTitle || "").localeCompare(b.dataset.catalogTitle || "");
      }
      return (b.dataset.catalogDate || "").localeCompare(a.dataset.catalogDate || "");
    }

    function render() {
      const size = Number(pageSize.value);
      const matched = rows.filter(matches).sort(compareRows);
      const totalPages = size > 0 ? Math.max(1, Math.ceil(matched.length / size)) : 1;
      page = Math.min(page, totalPages);
      const start = size > 0 ? (page - 1) * size : 0;
      const visible = new Set(size > 0 ? matched.slice(start, start + size) : matched);

      rows.forEach((row) => { row.hidden = true; });
      matched.forEach((row) => tbody.appendChild(row));
      matched.forEach((row) => { row.hidden = !visible.has(row); });

      count.textContent = `${matched.length} song${matched.length === 1 ? "" : "s"}`;
      pageStatus.textContent = size > 0 ? `Page ${page} of ${totalPages}` : "All results";
      prev.disabled = page <= 1 || size === 0;
      next.disabled = page >= totalPages || size === 0;
      empty.hidden = matched.length > 0;
    }

    browser.addEventListener("input", (e) => { if (e.target === search) { page = 1; render(); } });
    browser.addEventListener("change", (e) => {
      if ([type, artist, year, sort, pageSize].includes(e.target)) { page = 1; render(); }
    });
    prev.addEventListener("click", () => { page = Math.max(1, page - 1); render(); });
    next.addEventListener("click", () => { page += 1; render(); });
    render();
  }
</script>

<style>
  .catalog-browser {
    display: grid;
    gap: 20px;
  }

  /* Control bar — mirrors ReleaseBrowser.astro styles which are scoped there */
  .release-browser-controls {
    display: flex;
    flex-wrap: nowrap;
    gap: 10px;
    align-items: flex-end;
    padding: 16px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
  }

  .release-browser-controls label {
    display: grid;
    gap: 6px;
    flex: 0.65 0 78px;
    min-width: 0;
    color: var(--muted);
    font-size: 0.82rem;
    font-weight: 800;
  }

  .release-browser-search {
    flex: 1.6 0 160px;
  }

  .release-browser-controls input,
  .release-browser-controls select {
    width: 100%;
    min-height: 42px;
    border: 1px solid var(--line);
    border-radius: 6px;
    padding: 9px 10px;
    background: #ffffff;
    color: var(--ink);
    font: inherit;
  }

  .release-browser-summary,
  .release-browser-pages {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .release-browser-summary {
    justify-content: space-between;
    color: var(--muted);
    font-size: 0.92rem;
    font-weight: 700;
  }

  .release-browser-pages .button {
    background: var(--panel);
    color: var(--ink);
    cursor: pointer;
  }

  .release-browser-pages .button:disabled {
    cursor: default;
    opacity: 0.42;
  }

  .release-browser-empty {
    padding: 18px;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
  }

  .catalog-table-wrap {
    overflow-x: auto;
    border: 1px solid var(--line);
    border-radius: 8px;
    background: var(--panel);
  }

  .catalog-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 0.9rem;
  }

  .catalog-table thead th {
    padding: 12px 16px;
    text-align: left;
    font-size: 0.75rem;
    font-weight: 800;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--muted);
    border-bottom: 1px solid var(--line);
    white-space: nowrap;
  }

  .catalog-table tbody tr {
    border-bottom: 1px solid var(--line);
    transition: background var(--transition);
  }

  .catalog-table tbody tr:last-child {
    border-bottom: none;
  }

  .catalog-table tbody tr:hover {
    background: rgba(0, 0, 0, 0.025);
  }

  .catalog-table td {
    padding: 10px 16px;
    vertical-align: middle;
  }

  .catalog-table td a {
    color: var(--ink);
    text-decoration: none;
    font-weight: 600;
  }

  .catalog-table td a:hover {
    color: var(--green);
  }

  .catalog-mono {
    font-family: ui-monospace, "Cascadia Code", "Source Code Pro", monospace;
    font-size: 0.82rem;
    color: var(--muted);
    white-space: nowrap;
  }

  @media (max-width: 760px) {
    .catalog-browser {
      padding: 0 20px;
    }

    .release-browser-controls {
      flex-wrap: wrap;
    }

    .release-browser-controls label,
    .release-browser-search {
      flex: 1 0 100%;
    }

    .release-browser-summary {
      align-items: flex-start;
      flex-direction: column;
    }
  }
</style>

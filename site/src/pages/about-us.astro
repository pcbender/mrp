---
import BaseLayout from "../layouts/BaseLayout.astro";
import Breadcrumbs from "../components/Breadcrumbs.astro";

const aboutImage = "/assets/migrated/f38a42a461ad-AboutUsImage.png";
const heroImage = "/assets/wp/wp-content/uploads/2025/02/Two-Tree-Road-611x350.jpg";
---
<BaseLayout title="About Us | Maricopa Records" description="About Maricopa Records.">
  <section class="about-page-hero" style={`--about-hero-image: url("${heroImage}")`}>
    <h1>About Us</h1>
    <Breadcrumbs items={[{ label: "About Us" }]} />
  </section>

  <section class="about-content-panel">
    <h2>Welcome to Maricopa Records</h2>
    <div class="about-lead-grid">
      <img src={aboutImage} alt="" width="1024" height="1024" />
      <div>
        <p>
          Maricopa Records is an innovative music production and distribution company at the intersection of AI
          technology and analog creativity. We specialize in crafting unique music, lyrics, images, and videos using a
          fusion of cutting-edge artificial intelligence and traditional recording techniques. Our mission is to push
          the boundaries of artistic expression, creating fresh, genre-defying music that captivates audiences
          worldwide.
        </p>
        <p>
          With a commitment to authenticity and high-quality production, we embrace both the digital revolution and the
          warmth of analog sound. Our roster of artists includes groundbreaking AI-driven performers as well as human
          collaborators, all contributing to a sonic landscape that challenges conventions and redefines what's possible
          in modern music.
        </p>
        <p>
          At Maricopa Records, we are more than just a label - we are a creative powerhouse, a platform for artists,
          and a home for those who want to explore uncharted musical territories. Whether it's the high-energy 80s rock
          revival of STAB or the storytelling wisdom of PCBender, our artists represent a bold new era of sound and
          innovation.
        </p>
        <p><strong>Moving - Music - Forward</strong> - this is our passion, our mission, and our promise.</p>
      </div>
    </div>

    <div class="about-join-grid">
      <div>
        <p>
          Are you an artist looking for a label that embraces the future while honoring the past? Whether you're a
          musician, vocalist, producer, or AI-driven creator, we want to hear from you. Maricopa Records is always on
          the lookout for fresh talent who share our passion for music and innovation.
        </p>
        <p>What we offer:</p>
        <ul>
          <li>A forward-thinking approach to music production and distribution</li>
          <li>Access to AI-powered creative tools and high-quality analog recording techniques</li>
          <li>Collaboration with a diverse network of artists and producers</li>
          <li>Support in branding, promotion, and digital distribution</li>
        </ul>
        <p>
          If you have a unique sound, a fresh perspective, and a passion for breaking musical boundaries, we'd love to
          hear your work. Submit your <a href="/contact/">demo or portfolio</a> and let's make something extraordinary
          together.
        </p>
      </div>
      <aside>
        <h2>Join Us</h2>
        <blockquote>
          <p>Welcome to the future of music. Welcome to Maricopa Records.</p>
          <strong>Moving - Music - Forward</strong>
        </blockquote>
      </aside>
    </div>
  </section>
</BaseLayout>

<style>
  .about-page-hero {
    display: grid;
    place-items: center;
    width: min(100% - clamp(40px, 8vw, 112px), 1180px);
    min-height: 160px;
    margin: 0 auto;
    padding: clamp(24px, 4vw, 44px) clamp(20px, 4vw, 56px);
    color: #ffffff;
    text-align: center;
    background:
      linear-gradient(90deg, rgba(17, 17, 17, 0.62), rgba(17, 17, 17, 0.28), rgba(17, 17, 17, 0.62)),
      var(--about-hero-image),
      var(--green);
    background-position: center 42%;
    background-size: cover;
  }

  .about-page-hero h1 {
    margin: 0;
    font-size: clamp(2rem, 5vw, 3.8rem);
    font-weight: 400;
    line-height: 1;
    letter-spacing: 0;
  }

  .about-page-hero :global(.breadcrumbs) {
    color: rgba(255, 255, 255, 0.78);
  }

  .about-page-hero :global(.breadcrumbs li + li::before) {
    color: rgba(255, 255, 255, 0.45);
  }

  .about-content-panel {
    display: grid;
    gap: clamp(38px, 5vw, 72px);
    width: min(100% - clamp(40px, 8vw, 112px), 1180px);
    margin: clamp(48px, 6vw, 72px) auto;
    padding: clamp(24px, 4vw, 44px);
    border: 1px solid var(--line);
    border-radius: 4px;
    background: var(--panel);
    box-shadow: 0 8px 24px rgba(23, 23, 23, 0.06);
  }

  .about-content-panel > h2 {
    margin: 0;
    color: var(--green);
    text-align: center;
    font-size: clamp(1.8rem, 4vw, 3rem);
    font-weight: 400;
    line-height: 1.1;
    letter-spacing: 0;
  }

  .about-lead-grid,
  .about-join-grid {
    display: grid;
    grid-template-columns: minmax(280px, 0.95fr) minmax(0, 1fr);
    gap: clamp(28px, 5vw, 64px);
    align-items: start;
  }

  .about-lead-grid img {
    width: 100%;
    aspect-ratio: 1;
    object-fit: cover;
  }

  .about-lead-grid p,
  .about-join-grid p,
  .about-join-grid li {
    color: var(--muted);
    font-size: 1.03rem;
  }

  .about-lead-grid p,
  .about-join-grid p {
    margin: 0 0 22px;
  }

  .about-join-grid ul {
    display: grid;
    gap: 10px;
    margin: 0 0 22px;
    padding-left: 1.2rem;
  }

  .about-join-grid a {
    color: var(--red);
    text-decoration: none;
  }

  .about-join-grid aside {
    align-self: center;
    display: grid;
    gap: 18px;
    text-align: center;
  }

  .about-join-grid aside h2 {
    margin: 0;
    color: var(--red);
    font-size: clamp(3.4rem, 7vw, 5.2rem);
    font-weight: 700;
    line-height: 0.95;
    letter-spacing: 0;
  }

  .about-join-grid blockquote {
    margin: 0;
    color: var(--muted);
    font-size: 1.35rem;
  }

  .about-join-grid blockquote p {
    margin: 0 0 8px;
    font-size: inherit;
  }

  @media (max-width: 760px) {
    .about-page-hero,
    .about-content-panel {
      width: 100%;
    }

    .about-content-panel {
      margin: 0;
      border-left: 0;
      border-right: 0;
    }

    .about-lead-grid,
    .about-join-grid {
      grid-template-columns: 1fr;
    }

    .about-join-grid aside {
      text-align: left;
    }
  }
</style>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReleaseBrowser from "../../components/ReleaseBrowser.astro";
import { catalogReleases, releaseCardModel } from "../../lib/catalog";

const releases = catalogReleases().map(releaseCardModel);
---
<BaseLayout paneled={true} title="Releases | Maricopa Records" description="Singles, EPs, and albums from Maricopa Records.">
  <section class="page-heading centered-page">
    <p class="eyebrow">Releases</p>
    <p>Explore Maricopa Records releases</p>
  </section>
  <section class="page-grid centered-page">
    <ReleaseBrowser releases={releases} rich />
  </section>
</BaseLayout>

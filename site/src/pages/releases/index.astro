---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReleaseGrid from "../../components/ReleaseGrid.astro";
import { catalogReleases, releaseCardModel } from "../../lib/catalog";

const releases = catalogReleases().map(releaseCardModel);
---
<BaseLayout title="Releases | Maricopa Records" description="Singles, EPs, and albums from Maricopa Records.">
  <section class="page-heading">
    <p class="eyebrow">Releases</p>
    <h1>Singles, EPs, and albums</h1>
  </section>
  <section class="page-grid">
    <ReleaseGrid releases={releases} />
  </section>
</BaseLayout>

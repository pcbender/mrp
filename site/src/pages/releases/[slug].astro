---
import BaseLayout from "../../layouts/BaseLayout.astro";
import ReleaseLanding from "../../components/ReleaseLanding.astro";
import { getArtistById, getReleaseBySlug, getVisibleReleases } from "../../lib/content.js";

export function getStaticPaths() {
  return getVisibleReleases().map((release) => ({ params: { slug: release.slug } }));
}

const release = getReleaseBySlug(Astro.params.slug);
const artist = getArtistById(release.artist_id);
---
<BaseLayout paneled={true} title={release.seo.title} description={release.seo.description}>
  <ReleaseLanding release={release} artist={artist} />
</BaseLayout>

---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { allStructuredPosts } from "../../lib/posts.js";

const posts = allStructuredPosts();
---
<BaseLayout title="Posts | Maricopa Records" description="News and posts from Maricopa Records.">
  <section class="page-heading posts-heading">
    <h1>Posts</h1>
  </section>
  <section class="post-card-grid posts-index" aria-label="Posts">
    {posts.map((post) => (
      <PostCard post={post} />
    ))}
  </section>
</BaseLayout>

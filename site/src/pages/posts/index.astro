---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PostCard from "../../components/PostCard.astro";
import { allStructuredPosts } from "../../lib/posts.js";

const posts = allStructuredPosts();
---
<BaseLayout paneled={true} title="Posts | Maricopa Records" description="News and posts from Maricopa Records.">
  <section class="page-heading posts-heading centered-page">
    <p class="eyebrow">Posts</p>
  </section>
  <section class="post-card-grid posts-index" aria-label="Posts">
    {posts.map((post) => (
      <PostCard post={post} />
    ))}
  </section>
</BaseLayout>

<style>
  .posts-heading {
    padding-bottom: 8px;
  }

  .post-card-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(22px, 3vw, 34px);
    width: min(100% - clamp(40px, 8vw, 112px), 1180px);
    margin: 0 auto clamp(56px, 7vw, 92px);
  }

  @media (max-width: 1000px) {
    .post-card-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 760px) {
    .post-card-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

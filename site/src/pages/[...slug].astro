---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getMigratedRoutes, migratedDescription, migratedPathParam } from "../lib/content.js";

export function getStaticPaths() {
  return getMigratedRoutes().map((entry) => ({
    params: { slug: migratedPathParam(entry) },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const title = entry.seo?.title || entry.title;
const description = migratedDescription(entry);
---
<BaseLayout title={`${title} | Maricopa Records`} description={description}>
  <article class="migrated-content">
    <header class="page-heading">
      <p class="eyebrow">{entry.published_at ? "News" : "Page"}</p>
      <h1>{entry.title}</h1>
      {entry.excerpt && <p>{entry.excerpt}</p>}
    </header>
    <div class="wp-content" set:html={entry.content_html} />
  </article>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArtistCarousel from "../components/ArtistCarousel.astro";
import ReleaseCarousel from "../components/ReleaseCarousel.astro";
import { artistCards, latestReleases } from "../lib/catalog";

const artists = artistCards();
const releases = latestReleases();
---
<BaseLayout title="Maricopa Records" description="Independent releases from Maricopa Records.">
  <section class="page-heading centered-page home-intro">
    <p class="eyebrow">Maricopa Records</p>
    <h1>Moving Music Forward</h1>
    <p>Independent releases, artists, and stories from Maricopa Records. If you feel, it's real.</p>
  </section>

  <ReleaseCarousel releases={releases} variant="media" />
  <ArtistCarousel artists={artists} variant="media" />
</BaseLayout>

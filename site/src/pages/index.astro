---
import BaseLayout from "../layouts/BaseLayout.astro";
import ArtistCard from "../components/ArtistCard.astro";
import ReleaseCard from "../components/ReleaseCard.astro";
import { artistReleaseCount, getArtistById, getArtists, latestRelease, releaseCoverUrl } from "../lib/content.js";

const artists = getArtists();
const release = latestRelease();
const releaseArtist = release ? getArtistById(release.artist_id) : null;
---
<BaseLayout title="Maricopa Records" description="Independent releases from Maricopa Records.">
  <section class="hero">
    <div class="hero-copy">
      <p class="eyebrow">Maricopa Records</p>
      <h1>Moving Music Forward</h1>
      <p>If You Feel, It's Real</p>
      <div class="hero-actions">
        <a class="button primary" href="/releases/">Releases</a>
        <a class="button" href="/artists/">Artists</a>
      </div>
    </div>
    <div class="hero-art" aria-hidden="true">
      <img src="/assets/maricopa-mark.svg" alt="" width="180" height="180" />
    </div>
  </section>

  <section class="section-grid">
    <div>
      <p class="eyebrow">Latest</p>
      <h2>Release pipeline</h2>
    </div>
    <div class="card-grid">
      {release && (
        <ReleaseCard
          title={release.title}
          artist={releaseArtist?.name || release.artist_id}
          href={`/releases/${release.slug}/`}
          type={release.release_type}
          coverImage={releaseCoverUrl(release)}
        />
      )}
    </div>
  </section>

  <section class="section-grid">
    <div>
      <p class="eyebrow">Roster</p>
      <h2>Featured artists</h2>
    </div>
    <div class="card-grid">
      {artists.map((artist) => (
        <ArtistCard
          name={artist.name}
          href={`/artists/${artist.id}/`}
          summary={`${artistReleaseCount(artist.id)} public release${artistReleaseCount(artist.id) === 1 ? "" : "s"}`}
          image={artist.image}
        />
      ))}
    </div>
  </section>
</BaseLayout>
